# OpenE8 Governance OS - Environment Configurations

# Port the Express API server will listen on
PORT=5001

# JWT Signing Secret (Generate a strong cryptographic key in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Prisma database url (Optional: Defaults to local SQLite db: "file:./dev.db")
# For PostgreSQL production, uncomment and update:
# DATABASE_URL="postgresql://johndoe:mypassword@localhost:5432/mydb?schema=public"
